<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <property name="schema_name" value="tuxtepec"/>

    <changeSet id="001-crear-tablas-operativas-calculo" author="Hugo Cobos">
        <createTable tableName="lecturas_agua" schemaName="${schema_name}">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="predio_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_lectura" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="lectura_anterior" type="DECIMAL(12, 2)"/>
            <column name="lectura_actual" type="DECIMAL(12, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="consumo_m3" type="DECIMAL(12, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="bimestre" type="INT"/>
            <column name="anio" type="INT"/>
            <column name="observaciones" type="VARCHAR(255)"/>
        </createTable>

        <createIndex tableName="lecturas_agua" indexName="idx_lectura_predio">
            <column name="predio_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>