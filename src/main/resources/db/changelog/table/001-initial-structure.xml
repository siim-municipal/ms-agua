<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <property name="schema_name" value="tuxtepec"/>

    <changeSet id="001-create-contrato-agua" author="Hugo Cobos">
        <createTable tableName="contrato_agua" schemaName="${schema_name}">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="predio_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="numero_medidor" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="lectura_inicial" type="DECIMAL(10, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_toma" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="estatus" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_contrato_predio" tableName="contrato_agua">
            <column name="predio_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-lectura-agua" author="Hugo Cobos">
        <createTable tableName="lectura_agua" schemaName="${schema_name}">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_lectura_agua"/>
            </column>

            <column name="contrato_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_lectura_contrato"
                             references="contrato_agua(id)"/>
            </column>

            <column name="fecha_lectura" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="lectura_m3" type="DECIMAL(10, 2)">
                <constraints nullable="false"/>
            </column>

            <column name="observaciones" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex indexName="idx_lectura_contrato_fecha" tableName="lectura_agua">
            <column name="contrato_id"/>
            <column name="fecha_lectura" descending="true"/> </createIndex>
    </changeSet>

</databaseChangeLog>